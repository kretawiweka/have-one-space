# ==========================================
# Database (Supabase PostgreSQL)
# ==========================================
# Use the connection string from Supabase Dashboard > Settings > Database
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# Or with SSL: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require
DATABASE_URL="postgresql://postgres:password@db.projectref.supabase.co:5432/postgres?sslmode=require"

# ==========================================
# NextAuth
# ==========================================
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ==========================================
# Admin user (used by prisma/seed.ts)
# ==========================================
ADMIN_EMAIL="your@email.com"
ADMIN_PASSWORD="your-strong-password"
ADMIN_NAME="Your Name"

# ==========================================
# Analytics
# ==========================================
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-0YDW4852Q3"

# ==========================================
# Comments (Giscus)
# ==========================================
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPOSITORY_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# ==========================================
# Newsletter (Buttondown)
# ==========================================
BUTTONDOWN_API_KEY=
